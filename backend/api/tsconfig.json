{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@shared/*": ["../../shared/*"],
      "@swarm/shared": ["../../shared/index.ts"],
      "@swarm/shared-infra": ["../shared-infra/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
