{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@swarm/shared": ["../../shared/index.ts"],
      "@swarm/shared/*": ["../../shared/*"]
    }
  },
  "include": ["src/**/*"]
}
