{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@shared/*": ["../../shared/*"],
      "@swarm/shared": ["../../shared/index.ts"],
      "@swarm/shared-infra": ["../shared-infra/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
