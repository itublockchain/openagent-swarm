{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "outDir": "./dist",
    "baseUrl": "../..",
    "paths": {
      "@swarm/shared": ["shared/index.ts"],
      "@swarm/shared/*": ["shared/*"]
    }
  },
  "include": ["./**/*", "../../shared/**/*"]
}