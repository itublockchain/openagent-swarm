# =============================================================================
# 0G Chain (shared by Storage + L2 contracts — same EVM)
# =============================================================================
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_URL=https://indexer-storage-testnet-standard.0g.ai
# Signer used by ZeroGStorage (uploads) AND L2Contract (DAG / escrow / vault txs).
# Required when USE_ZG_STORAGE=true or USE_L2=true.
PRIVATE_KEY=

# =============================================================================
# 0G Compute
# =============================================================================
ZG_COMPUTE_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
# Wallet used by the 0G Serving Broker for inference billing. Can be the same
# as PRIVATE_KEY, or a dedicated key if you want compute spend isolated.
AGENT_PRIVATE_KEY=
# Initial 0G fund for the broker ledger sub-account when one is auto-created.
# Units are in 0G. Set higher (e.g. 0.1) if you expect long DAGs.
ZG_COMPUTE_INITIAL_FUND=0.01

# =============================================================================
# Storage selection
# =============================================================================
USE_ZG_STORAGE=false
# When true and USE_ZG_STORAGE=true, falls back to MockStorage on 0G failures.
STORAGE_FALLBACK=false
# Optional shared dir for MockStorage across processes (default: <tmp>/swarm-mock-storage)
MOCK_STORAGE_DIR=

# =============================================================================
# Chain selection
# =============================================================================
USE_L2=false
# Optional overrides for the 0G testnet contract addresses (swarm side).
# When unset, addresses are loaded from contracts/deployments/og_testnet.json.
L2_DAG_REGISTRY_ADDRESS=
L2_ESCROW_ADDRESS=
L2_SLASHING_VAULT_ADDRESS=
L2_AGENT_REGISTRY_ADDRESS=
L2_TREASURY_ADDRESS=

# =============================================================================
# Base Sepolia (payment gateway)
# =============================================================================
# Real USDC custody lives on Base Sepolia. The API operator EOA bridges
# Deposited events into Treasury.balanceOf on 0G, and signs `release` on
# Gateway when a user withdraws. Same PRIVATE_KEY as 0G — one operator key
# spans both chains.
BASE_RPC_URL=https://sepolia.base.org
# Circle's canonical Base Sepolia USDC. Deploy script defaults to this if unset.
BASE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# USDCGateway address. Loaded from contracts/deployments/base_sepolia.json
# when unset; override here for a non-default deployment.
BASE_GATEWAY_ADDRESS=
# Where BridgeWatcher persists its cursor + processed-event keys. Inside
# the API container the agents-data volume is already mounted here.
BRIDGE_STATE_DIR=/data

# =============================================================================
# Agent persistence (API-side)
# =============================================================================
# AES-256-GCM key for the on-disk agent secret store. Accepts either a 64-char
# hex string (32 bytes — preferred) or any UTF-8 passphrase (will be SHA-256
# hashed to a key). Required: losing this key permanently locks every agent's
# private key in the volume.
#   Generate one with:  openssl rand -hex 32
MASTER_KEY=
# Path inside the API container where the encrypted secret store lives. The
# docker-compose mount maps a named volume here so the file survives
# `docker compose down/up`.
AGENT_SECRETS_PATH=/data/agent-secrets.json

# =============================================================================
# AXL Network
# =============================================================================
# HTTP bridge URL of the local AXL daemon (sidecar pattern).
# Defaults to http://127.0.0.1:9002 when unset.
AXL_URL=
# Bootstrap peer for the AXL daemon (consumed by docker / start scripts).
AXL_PEER=tcp://axl-seed:7000

# =============================================================================
# Agent
# =============================================================================
AGENT_ID=swarm-genesis
STAKE_AMOUNT=100
# Optional override for the system prompt used by compute adapters.
AGENT_SYSTEM_PROMPT=

# =============================================================================
# API
# =============================================================================
PORT=3001
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_HOST=
API_WS_URL=ws://api:3001/ws

# =============================================================================
# Compute mode
# =============================================================================
# How agents reach 0G Compute:
#   central — shared API-side broker (default; cheapest, ~3 OG total ledger)
#   local   — every agent holds its own broker + ledger (~3 OG per agent)
#   mock    — deterministic stub, no network (tests / dev)
COMPUTE_MODE=central
# Optional CSV of extra private keys to add to the API's compute pool. Demo
# uses just PRIVATE_KEY; for mainnet scale extend with isolated wallets so
# the 0G Compute provider's per-wallet rate limit doesn't bottleneck the
# entire swarm. Example:
#   COMPUTE_POOL_KEYS=0xabc...,0xdef...
COMPUTE_POOL_KEYS=

# =============================================================================
# Dev
# =============================================================================
USE_MOCK=true

# =============================================================================
# Production hardening — required when NODE_ENV=production
# =============================================================================
# JWT_SECRET=
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
# Base Sepolia USDC (Circle FiatTokenV2). Default in lib/env.ts is the
# canonical testnet USDC; override only for a private test deployment.
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# USDCGateway address on Base Sepolia. Required for the Deposit modal.
# Read from contracts/deployments/base_sepolia.json after deploy-base.ts runs.
NEXT_PUBLIC_GATEWAY_ADDRESS=

# Contract addresses (0G Galileo testnet)
NEXT_PUBLIC_USDC_ADDRESS=0xcbF0cC20e36daf2689EA61632dA68B7fe9C22342
NEXT_PUBLIC_ESCROW_ADDRESS=0x94fb6508EcfDa3FE6D2A8ed6c8d01fb81a237d48
NEXT_PUBLIC_TREASURY_ADDRESS=0xcAa459ec1dF4004CeBA5712A6A01F013d9B00a74

# ─── Backend / Agent Runtime ───
MASTER_KEY=1034c2bcb225e412b0b73e18f51de852ca4ebddfc87c79ce7c2cf8231dc38e02
JWT_SECRET=swarm-dev-secret-key-1234
PRIVATE_KEY=10c7172efc65e5dc6b3be55472935f8183e51a2019b540e6a54aa2b38b87b4dd

# Production (separate file: .env.prod, not tracked)
# PROD_USDC_ADDRESS=
# PROD_ESCROW_ADDRESS=
# PROD_TREASURY_ADDRESS=