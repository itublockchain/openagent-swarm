# 0G Storage
ZG_STORAGE_URL=
ZG_STORAGE_PRIVATE_KEY=

# 0G Compute
ZG_COMPUTE_URL=
ZG_COMPUTE_API_KEY=

# AXL Network
AXL_WS_URL=
AXL_NETWORK_ID=swarm-devnet

# L2 Contract
L2_RPC_URL=
L2_PRIVATE_KEY=
L2_ESCROW_ADDRESS=
L2_DAG_REGISTRY_ADDRESS=
L2_SLASHING_VAULT_ADDRESS=
L2_REQUIRED_CONFIRMATIONS=1
L2_TX_TIMEOUT_MS=30000

# Agent
AGENT_ID=agent-1
STAKE_AMOUNT=100

# API
PORT=3001
# Production: tcp://docker-proxy:2375
# Local dev: leave empty, socket will be used
DOCKER_HOST=

# Local dev ONLY (do not use in production)
DOCKER_SOCKET=/var/run/docker.sock

# Dev
USE_MOCK=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
