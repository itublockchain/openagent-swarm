# =============================================================================
# 0G Chain (shared by Storage + L2 contracts — same EVM)
# =============================================================================
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_URL=https://indexer-storage-testnet-standard.0g.ai
# Signer used by ZeroGStorage (uploads) AND L2Contract (DAG / escrow / vault txs).
# Required when USE_ZG_STORAGE=true or USE_L2=true.
PRIVATE_KEY=

# =============================================================================
# 0G Compute
# =============================================================================
ZG_COMPUTE_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
# Wallet used by the 0G Serving Broker for inference billing. Can be the same
# as PRIVATE_KEY, or a dedicated key if you want compute spend isolated.
AGENT_PRIVATE_KEY=
# Initial 0G fund for the broker ledger sub-account when one is auto-created.
# Units are in 0G. Set higher (e.g. 0.1) if you expect long DAGs.
ZG_COMPUTE_INITIAL_FUND=0.01

# =============================================================================
# Storage selection
# =============================================================================
USE_ZG_STORAGE=false
# When true and USE_ZG_STORAGE=true, falls back to MockStorage on 0G failures.
STORAGE_FALLBACK=false
# Optional shared dir for MockStorage across processes (default: <tmp>/swarm-mock-storage)
MOCK_STORAGE_DIR=

# =============================================================================
# Chain selection
# =============================================================================
USE_L2=false
# Optional overrides for the L2 contract addresses.
# When unset, addresses are loaded from contracts/deployments/og_testnet.json.
L2_DAG_REGISTRY_ADDRESS=
L2_ESCROW_ADDRESS=
L2_SLASHING_VAULT_ADDRESS=
L2_AGENT_REGISTRY_ADDRESS=
# Token used by the escrow (defaults to the deployed MockERC20).
# Set to the real USDC address for production.
L2_USDC_ADDRESS=

# =============================================================================
# Agent persistence (API-side)
# =============================================================================
# AES-256-GCM key for the on-disk agent secret store. Accepts either a 64-char
# hex string (32 bytes — preferred) or any UTF-8 passphrase (will be SHA-256
# hashed to a key). Required: losing this key permanently locks every agent's
# private key in the volume.
#   Generate one with:  openssl rand -hex 32
MASTER_KEY=
# Path inside the API container where the encrypted secret store lives. The
# docker-compose mount maps a named volume here so the file survives
# `docker compose down/up`.
AGENT_SECRETS_PATH=/data/agent-secrets.json

# =============================================================================
# AXL Network
# =============================================================================
# HTTP bridge URL of the local AXL daemon (sidecar pattern).
# Defaults to http://127.0.0.1:9002 when unset.
AXL_URL=
# Bootstrap peer for the AXL daemon (consumed by docker / start scripts).
AXL_PEER=tcp://axl-seed:7000

# =============================================================================
# Agent
# =============================================================================
AGENT_ID=swarm-genesis
STAKE_AMOUNT=100
# Optional override for the system prompt used by compute adapters.
AGENT_SYSTEM_PROMPT=

# =============================================================================
# API
# =============================================================================
PORT=3001
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_HOST=
API_WS_URL=ws://api:3001/ws

# =============================================================================
# Dev
# =============================================================================
USE_MOCK=true

# =============================================================================
# Production hardening — required when NODE_ENV=production
# =============================================================================
# JWT_SECRET=
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# =============================================================================
# OpenAI (alternative compute backend)
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# =============================================================================
# Agent tools
# =============================================================================
# Tavily web search API key (preferred — returns content snippets directly).
# Without a key, the WebSearch tool falls through to Brave then DuckDuckGo IA.
TAVILY_API_KEY=
# Brave Search API key (fallback after Tavily). Free tier 2000 req/month.
# Recommended: at least one of TAVILY/BRAVE set, since DDG IA only answers
# Wikipedia-style queries and returns nothing for most prompts.
BRAVE_API_KEY=
# Internal URL agents use to reach the API for the CodeExecutor sandbox
# endpoint. Defaults to http://api:3001 inside the swarm_default network.
API_INTERNAL_URL=

#SECRET FOR STROAGE OF AGENTS
MASTER_KEY=