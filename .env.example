# 0G Storage
ZG_STORAGE_URL=
ZG_STORAGE_PRIVATE_KEY=

# 0G Compute
ZG_COMPUTE_URL=
ZG_COMPUTE_API_KEY=

# AXL Network
AXL_WS_URL=
